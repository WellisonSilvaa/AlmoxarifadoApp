# ⚠️ CONFIGURAÇÃO DO FIREBASE - NUNCA COMMITE ESTE ARQUIVO COM DADOS REAIS
# Copie este arquivo para .env.local e preencha com seus dados

# Obtém estas informações em: https://firebase.google.com/docs/web/setup
EXPO_PUBLIC_FIREBASE_API_KEY=sua_api_key_aqui
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=seu_project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=seu_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=seu_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=seu_messaging_id
EXPO_PUBLIC_FIREBASE_APP_ID=seu_app_id
